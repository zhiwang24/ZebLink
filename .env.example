# Optional Redis storage for Vercel or multi-instance deployments.
# CozyCast accepts either Vercel KV-style or raw Upstash-style names.
# KV_REST_API_URL=https://example.upstash.io
# KV_REST_API_TOKEN=replace-me
# UPSTASH_REDIS_REST_URL=https://example.upstash.io
# UPSTASH_REDIS_REST_TOKEN=replace-me

# Option 1: full ICE server list as JSON
# ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"cozycast","credential":"replace-me"}]

# Option 2: single TURN server alongside the default public STUN server
# TURN_URL=turn:turn.example.com:3478
# TURN_USERNAME=cozycast
# TURN_CREDENTIAL=replace-me
